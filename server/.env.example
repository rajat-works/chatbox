# ============================================
# CoreChat Server Environment Variables
# ============================================

# Application
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/corechat

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# OTP
OTP_EXPIRATION_MINUTES=5

# Encryption (for E2E message encryption)
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Email (SMTP) - for OTP & notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM="CoreChat <noreply@corechat.com>"

# File Upload Limits
MAX_FILE_SIZE_MB=25
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=50

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# WebRTC TURN/STUN (for voice/video calls)
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_USERNAME=your-turn-username
TURN_CREDENTIAL=your-turn-credential
STUN_SERVER_URL=stun:stun.l.google.com:19302
